# Copy this file to: .streamlit/secrets.toml
# Never commit secrets.toml (it is listed in .gitignore).
#
# If no passwords are configured, the login screen is skipped (local dev).
#
# Use ONE of these patterns:
#
# Single shared password:
# app_password = "your-shared-password"

# Or multiple valid passwords (e.g. two teams / rotation):
# app_passwords = ["first-shared-secret", "second-shared-secret"]

# Resend (required for Send Group Report / Send Individual Emails):
resend_api_key = "re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
resend_from    = "onboarding@resend.dev"
